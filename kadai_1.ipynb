        "# 値の設定（cm）\n",
        "上辺 = 10\n",
        "下辺 = 20\n",
        "高さ = 5\n",
        "\n",
        "# 台形の面積計算\n",
        "面積 = (上辺 + 下辺) * 高さ / 2\n",
        "\n",
        "# 結果出力（単位付き）\n",
        "print(f\"{面積}cm²\")"
